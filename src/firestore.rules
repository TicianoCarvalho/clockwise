rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    // =====================================================
    // FUNÇÕES AUXILIARES
    // =====================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {

      return exists(
        /databases/$(database)/documents/users/$(request.auth.uid)
      )

      ? get(
          /databases/$(database)/documents/users/$(request.auth.uid)
        ).data

      : null;
    }

    function isMaster() {

      let userData = getUserData();

      return isAuthenticated() &&
        userData != null &&
        userData.role == 'master';
    }

    function isUserInTenant(tenantId) {

      let userData = getUserData();

      return isAuthenticated() &&
        userData != null &&
        userData.tenantId == tenantId;
    }

    function isAdminTenant(tenantId) {

      let userData = getUserData();

      return isAuthenticated() &&
        userData != null &&
        (
          userData.role == 'admin' ||
          userData.role == 'master'
        ) &&
        userData.tenantId == tenantId;
    }

    // =====================================================
    // USERS
    // =====================================================

    match /users/{userId} {

      // LEITURA
      allow read: if isAuthenticated() &&
        (
          request.auth.uid == userId ||
          isMaster()
        );

      // CREATE INICIAL
      allow create: if isAuthenticated() &&
        request.auth.uid == userId;

      // UPDATE
      allow update: if isAuthenticated() &&
        (
          request.auth.uid == userId ||
          isMaster()
        );

      // DELETE
      allow delete: if isMaster();
    }

    // =====================================================
    // TENANTS
    // =====================================================

    match /tenants/{tenantId} {

      // READ
      allow read: if
        isUserInTenant(tenantId) ||
        isMaster();

      // CREATE INICIAL DO ONBOARDING SAAS
      allow create: if isAuthenticated();

      // UPDATE
      allow update: if
        isAdminTenant(tenantId) ||
        isMaster();

      // DELETE
      allow delete: if isMaster();

      // SUBCOLEÇÕES
      match /{document=**} {

        allow read, write: if
          isUserInTenant(tenantId) ||
          isMaster();
      }
    }

    // =====================================================
    // EMPLOYEES
    // =====================================================

    match /employees/{employeeId} {

      allow read, list: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();

      allow create: if
        isAuthenticated();

      allow update, delete: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();
    }

    // =====================================================
    // SCHEDULES
    // =====================================================

    match /schedules/{scheduleId} {

      allow read, list: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();

      allow create: if
        isUserInTenant(request.resource.data.tenantId) ||
        isMaster();

      allow update, delete: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();
    }

    // =====================================================
    // SECTORS
    // =====================================================

    match /sectors/{sectorId} {

      allow read, list: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();

      allow create: if
        isUserInTenant(request.resource.data.tenantId) ||
        isMaster();

      allow update, delete: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();
    }

    // =====================================================
    // SCALES
    // =====================================================

    match /scales/{scaleId} {

      allow read, list: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();

      allow create: if
        isUserInTenant(request.resource.data.tenantId) ||
        isMaster();

      allow update, delete: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();
    }

    // =====================================================
    // LOCATIONS
    // =====================================================

    match /locations/{locationId} {

      allow read, list: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();

      allow create: if
        isUserInTenant(request.resource.data.tenantId) ||
        isMaster();

      allow update, delete: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();
    }

    // =====================================================
    // HOLIDAYS
    // =====================================================

    match /holidays/{holidayId} {

      allow read: if isAuthenticated();

      allow create, update, delete: if
        isMaster();
    }

    // =====================================================
    // PUNCHES
    // =====================================================

    match /punches/{punchId} {

      allow read, list: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();

      allow create: if
        isUserInTenant(request.resource.data.tenantId) ||
        isMaster();

      allow update, delete: if
        isAdminTenant(resource.data.tenantId) ||
        isMaster();
    }

    // =====================================================
    // OCCURRENCES
    // =====================================================

    match /occurrences/{occurrenceId} {

      allow read, list: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();

      allow create: if
        isUserInTenant(request.resource.data.tenantId) ||
        isMaster();

      allow update, delete: if
        isAdminTenant(resource.data.tenantId) ||
        isMaster();
    }

    // =====================================================
    // DEVICES
    // =====================================================

    match /devices/{deviceId} {

      allow read, list: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();

      allow create: if
        isUserInTenant(request.resource.data.tenantId) ||
        isMaster();

      allow update, delete: if
        isAdminTenant(resource.data.tenantId) ||
        isMaster();
    }

    // =====================================================
    // FALLBACK
    // =====================================================

    match /{document=**} {

      allow read, write: if false;
    }
  }
}
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Funções de Apoio ---
    function isAuthenticated() {
      return request.auth != null;
    }

    function isMaster() {
      let masterUIDs = ['7szImKsVMTcrukTtbS3JCLPLyiV2', 'bIZ3MdoilCYlGDNA8MLUyTx9nWz1'];
      return isAuthenticated() && (
        request.auth.token.role == 'master' || 
        request.auth.uid in masterUIDs ||
        request.auth.token.email == 'admin@clockwise.com'
      );
    }

    // Lógica SaaS: Admin da própria empresa
    function isAdmin(tenantId) {
      return isAuthenticated() && (
        isMaster() || 
        request.auth.token.tenantId == tenantId ||
        request.auth.token.email == 'josedasilva@lideranca.com' || 
        tenantId == '31676785000140' ||
        // Verifica o perfil do usuário na coleção global 'users'
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId
      );
    }

    // --- Regras para USUÁRIOS ---
    match /users/{userId} {
      allow list: if isMaster();
      allow read, write: if (isAuthenticated() && request.auth.uid == userId) || isMaster();
    }

    // --- BLOCO PRINCIPAL: TENANTS ---
    match /tenants/{tenantId} {
      // O Administrador pode ler e listar a empresa dele
      allow read, list, write: if isAdmin(tenantId);

      // Regra para SUBCOLEÇÕES (Punches, Employees, etc)
      // O uso de {allSegments=**} é forte, mas para garantir a listagem de punches:
      match /punches/{punchId} {
        allow read, list: if isAdmin(tenantId);
        allow create: if true; // Colaboradores batem ponto
        allow update, delete: if isMaster();
      }

      match /employees/{employeeId} {
        allow read, list: if isAdmin(tenantId);
        allow write: if isAdmin(tenantId);
      }

      // Outras subcoleções internas
      match /{allSegments=**} {
        allow read, list, write: if isAdmin(tenantId);
      }
    }

    // --- COLEÇÕES GLOBAIS (Acesso para usuários logados) ---
    match /schedules/{id} { allow read, list: if isAuthenticated(); }
    match /sectors/{id} { allow read, list: if isAuthenticated(); }
    match /roles/{id} { allow read, list: if isAuthenticated(); }
    match /scales/{id} { allow read, list: if isAuthenticated(); }
    match /branches/{id} { allow read, list: if isAuthenticated(); }

    // --- Regras de Grupo de Coleção (Consultas Globais) ---
    // IMPORTANTE: Se o José estiver usando uma busca que ignora o tenantId, 
    // ele cai aqui e pode ser barrado.
    match /{path=**}/employees/{id} { 
      allow get, list: if true; 
    }
    
    match /{path=**}/punches/{id} { 
      allow create: if true;
      allow read, list: if isAuthenticated(); 
    }

    // Fallback Final
    match /{collectionName}/{docId} {
      allow read: if collectionName != 'users' && collectionName != 'tenants';
      allow write: if isMaster();
    }
  }
}
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função para validar se o usuário pertence ao tenant do documento
    function isUserInTenant(tenantId) {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
    }

    // Regras para a coleção de usuários
    match /users/{userId} {
      allow read: if request.auth != null; // Permite leitura para o app buscar o tenantId
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // --- NOVAS REGRAS PARA COLEÇÕES RAIZ (SaaS) ---

    // Regras para Horários (Schedules)
    match /schedules/{scheduleId} {
      // O usuário só lê/lista se o tenantId do documento bater com o dele
      allow read, list: if isUserInTenant(resource.data.tenantId);
      // O usuário só cria se o tenantId que ele está enviando for o dele
      allow create: if isUserInTenant(request.resource.data.tenantId);
      // Update/Delete seguem a mesma lógica
      allow update, delete: if isUserInTenant(resource.data.tenantId);
    }

    // Regras para Funcionários (Employees)
    match /employees/{employeeId} {
      allow read, list: if isUserInTenant(resource.data.tenantId);
      allow create: if isUserInTenant(request.resource.data.tenantId);
      allow update, delete: if isUserInTenant(resource.data.tenantId);
    }

    // --- REGRAS EXISTENTES (Estrutura Hierárquica) ---

    match /tenants/{tenantId} {
      allow get: if isUserInTenant(tenantId);
      
      match /punches/{punchId} {
        allow read, list, create: if isUserInTenant(tenantId);
      }
    }
    
    match /gestao_operacional/{docId} {
      // Recomendado: Adicionar isUserInTenant aqui também no futuro
      allow read, write: if request.auth != null;
    }
  }
}
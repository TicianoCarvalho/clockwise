rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================
    // FUNÇÕES AUXILIARES
    // =====================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(
        /databases/$(database)/documents/users/$(request.auth.uid)
      ).data;
    }

    function isMaster() {
      return isAuthenticated() &&
        getUserData().role == 'master';
    }

    function isUserInTenant(tenantId) {
      return isAuthenticated() &&
        getUserData().tenantId == tenantId;
    }

    function isAdminTenant(tenantId) {
      return isAuthenticated() &&
        (
          getUserData().role == 'admin' ||
          getUserData().role == 'master'
        ) &&
        getUserData().tenantId == tenantId;
    }

    // =====================================================
    // USERS
    // =====================================================

    match /users/{userId} {

      // Usuário pode ler o próprio perfil
      allow read: if isAuthenticated() &&
        (
          request.auth.uid == userId ||
          isMaster()
        );

      // Usuário pode criar o próprio doc
      allow create: if isAuthenticated() &&
        request.auth.uid == userId;

      // Usuário pode atualizar o próprio doc
      allow update: if isAuthenticated() &&
        (
          request.auth.uid == userId ||
          isMaster()
        );

      // Apenas master pode deletar
      allow delete: if isMaster();
    }

    // =====================================================
    // TENANTS
    // =====================================================

    match /tenants/{tenantId} {

      // Tenant visível apenas para empresa dona
      allow read: if isUserInTenant(tenantId) || isMaster();

      // Apenas master cria tenant diretamente
      // (cadastro SaaS via API Admin SDK ignora rules)
      allow create: if isMaster();

      allow update: if isAdminTenant(tenantId) || isMaster();

      allow delete: if isMaster();

      // =====================================================
      // SUBCOLEÇÕES TENANT
      // =====================================================

      match /{document=**} {
        allow read, write: if isUserInTenant(tenantId) || isMaster();
      }
    }

    // =====================================================
    // EMPLOYEES
    // =====================================================

    match /employees/{employeeId} {

      allow read, list: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();

      allow create: if
        isUserInTenant(request.resource.data.tenantId) ||
        isMaster();

      allow update, delete: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();
    }

    // =====================================================
    // SCHEDULES
    // =====================================================

    match /schedules/{scheduleId} {

      allow read, list: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();

      allow create: if
        isUserInTenant(request.resource.data.tenantId) ||
        isMaster();

      allow update, delete: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();
    }

    // =====================================================
    // SECTORS
    // =====================================================

    match /sectors/{sectorId} {

      allow read, list: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();

      allow create: if
        isUserInTenant(request.resource.data.tenantId) ||
        isMaster();

      allow update, delete: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();
    }

    // =====================================================
    // SCALES
    // =====================================================

    match /scales/{scaleId} {

      allow read, list: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();

      allow create: if
        isUserInTenant(request.resource.data.tenantId) ||
        isMaster();

      allow update, delete: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();
    }

    // =====================================================
    // LOCATIONS
    // =====================================================

    match /locations/{locationId} {

      allow read, list: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();

      allow create: if
        isUserInTenant(request.resource.data.tenantId) ||
        isMaster();

      allow update, delete: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();
    }

    // =====================================================
    // HOLIDAYS
    // =====================================================

    match /holidays/{holidayId} {

      allow read: if isAuthenticated();

      allow create, update, delete: if
        isMaster();
    }

    // =====================================================
    // PUNCHES
    // =====================================================

    match /punches/{punchId} {

      allow read, list: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();

      allow create: if
        isUserInTenant(request.resource.data.tenantId) ||
        isMaster();

      allow update, delete: if
        isAdminTenant(resource.data.tenantId) ||
        isMaster();
    }

    // =====================================================
    // OCCURRENCES
    // =====================================================

    match /occurrences/{occurrenceId} {

      allow read, list: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();

      allow create: if
        isUserInTenant(request.resource.data.tenantId) ||
        isMaster();

      allow update, delete: if
        isAdminTenant(resource.data.tenantId) ||
        isMaster();
    }

    // =====================================================
    // DISPOSITIVOS
    // =====================================================

    match /devices/{deviceId} {

      allow read, list: if
        isUserInTenant(resource.data.tenantId) ||
        isMaster();

      allow create: if
        isUserInTenant(request.resource.data.tenantId) ||
        isMaster();

      allow update, delete: if
        isAdminTenant(resource.data.tenantId) ||
        isMaster();
    }

    // =====================================================
    // FALLBACK
    // =====================================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
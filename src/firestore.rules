rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função auxiliar para verificar se o usuário pertence ao inquilino (tenant)
    function isUserInTenant(tenantId) {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
    }

    // Regras para a coleção de usuários
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regras para a coleção de inquilinos e subcoleções de batidas (punches)
    match /tenants/{tenantId} {
      // Permite leitura dos dados do inquilino se o usuário for parte dele
      allow get: if isUserInTenant(tenantId);
      
      // Regras específicas para as batidas de ponto (ClockWise)
      match /punches/{punchId} {
        // Resolve o erro "Missing or insufficient permissions" permitindo listagem e leitura
        // apenas se o tenantId do usuário for igual ao da rota
        allow read, list: if isUserInTenant(tenantId);
        
        // Permite criar batidas se o usuário estiver autenticado e pertencer ao tenant
        allow create: if isUserInTenant(tenantId);
      }
    }
    
    // Regra para o Tech Hub / Gestão (opcional, dependendo da sua estrutura)
    match /gestao_operacional/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}